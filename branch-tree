#!/usr/bin/env python3
# branch-tree: ブランチの親子関係をツリー表示する
# Usage: branch-tree [--pr] [--html] [--open] [branch]
# 依存: gh (GitHub CLI), git

import subprocess
import sys
import json
import argparse
import os
import re
from urllib.parse import quote

# カラー
RED    = '\033[0;31m'
GREEN  = '\033[0;32m'
YELLOW = '\033[0;33m'
CYAN   = '\033[0;36m'
BOLD   = '\033[1m'
RESET  = '\033[0m'

ROOT_BRANCH = "develop"
CONFIG_FILE = ".branch-tree"


def get_repo_root():
    result = subprocess.run(
        ["git", "rev-parse", "--show-toplevel"],
        capture_output=True, text=True
    )
    return result.stdout.strip() if result.returncode == 0 else None


def load_root_branch():
    """リポジトリルートの .branch-tree からルートブランチを読み込む。なければ None。"""
    repo_root = get_repo_root()
    if not repo_root:
        return None
    config_path = os.path.join(repo_root, CONFIG_FILE)
    if os.path.exists(config_path):
        with open(config_path) as f:
            value = f.read().strip()
            return value if value else None
    return None


def save_root_branch(branch):
    """リポジトリルートの .branch-tree にルートブランチを保存する。"""
    repo_root = get_repo_root()
    if not repo_root:
        print("Warning: gitリポジトリが見つからないため設定を保存できません", file=sys.stderr)
        return
    config_path = os.path.join(repo_root, CONFIG_FILE)
    with open(config_path, "w") as f:
        f.write(branch + "\n")
    print(f"設定を保存しました: {config_path} (root={branch})", file=sys.stderr)

_pr_cache = {}
_issue_cache = {}
_repo_url = None
_repo_owner = None
_repo_name = None


def run(cmd):
    result = subprocess.run(cmd, capture_output=True, text=True)
    return result.stdout.strip()


def gh_json(args):
    """gh コマンドを実行してJSONを返す。失敗時は None。"""
    result = subprocess.run(["gh"] + args, capture_output=True, text=True)
    if result.returncode != 0:
        return None
    try:
        return json.loads(result.stdout)
    except json.JSONDecodeError:
        return None


def get_repo_info():
    global _repo_url, _repo_owner, _repo_name
    if _repo_url is None:
        data = gh_json(["repo", "view", "--json", "url,owner,name"])
        if data:
            _repo_url   = data["url"]
            _repo_owner = data["owner"]["login"]
            _repo_name  = data["name"]
        else:
            _repo_url = _repo_owner = _repo_name = ""


def get_repo_url():
    get_repo_info()
    return _repo_url


def branch_url(branch):
    return f"{get_repo_url()}/tree/{quote(branch, safe='/')}"


def get_linked_issues(pr_number):
    """PRに紐づくissueのリストを返す。なければ []。"""
    if pr_number in _issue_cache:
        return _issue_cache[pr_number]
    get_repo_info()
    query = (
        f'{{ repository(owner:"{_repo_owner}", name:"{_repo_name}") '
        f'{{ pullRequest(number:{pr_number}) '
        f'{{ closingIssuesReferences(first:10) {{ nodes {{ number title url }} }} }} }} }}'
    )
    result = subprocess.run(
        ["gh", "api", "graphql", "-f", f"query={query}"],
        capture_output=True, text=True
    )
    issues = []
    if result.returncode == 0:
        try:
            data = json.loads(result.stdout)
            nodes = (data.get("data", {})
                        .get("repository", {})
                        .get("pullRequest", {})
                        .get("closingIssuesReferences", {})
                        .get("nodes", []))
            issues = nodes
        except (json.JSONDecodeError, AttributeError):
            pass
    _issue_cache[pr_number] = issues
    return issues


def get_pr_info(branch):
    """ブランチのPR情報 (number, title, url) を返す。なければ None。"""
    if branch in _pr_cache:
        return _pr_cache[branch]
    data = gh_json(["pr", "list", "--head", branch, "--json", "number,title,url", "--limit", "1"])
    result = data[0] if data else None
    _pr_cache[branch] = result
    return result


def get_base_branch(branch):
    """gh PR からベースブランチを取得。PRなければ None。"""
    data = gh_json(["pr", "list", "--head", branch, "--json", "baseRefName", "--limit", "1"])
    if data:
        return data[0]["baseRefName"]
    return None


def collect_ancestors(branch):
    """branch から ROOT_BRANCH まで祖先を収集。ROOT_BRANCH を先頭に含むリストを返す。"""
    chain = []
    current = branch
    visited = set()
    while True:
        if current in visited:
            break
        visited.add(current)
        base = get_base_branch(current)
        if not base:
            chain.insert(0, current)
            break
        chain.insert(0, base)
        current = base
        if base == ROOT_BRANCH:
            break
    return chain


def get_children(branch):
    """gh PR でベースが branch のヘッドブランチ一覧を返す。"""
    data = gh_json(["pr", "list", "--base", branch, "--json", "headRefName", "--limit", "50"])
    if not data:
        return []
    return [pr["headRefName"] for pr in data]


# ===== CUI出力 =====

def print_node_lines(pr_info, connector_prefix, child_prefix, show_pr):
    """issue → PR → branch の順で出力する補助関数。
    connector_prefix: ├── や └── を含む行頭
    child_prefix:     その下の行（branch行・issue行）のインデント
    show_pr=False のときはPR/issue行を出力しない。
    branch行自体は呼び出し元で出力する。
    """
    if not show_pr:
        return
    if not pr_info:
        print(f"{connector_prefix}{RED}(no PR){RESET}")
        return
    num   = pr_info["number"]
    title = pr_info["title"]
    # issues
    issues = get_linked_issues(num)
    for issue in issues:
        print(f"{connector_prefix}{GREEN}#{issue['number']}{RESET} {issue['title']}")
        connector_prefix = child_prefix  # 2件目以降はchild_prefixに揃える
    # PR
    print(f"{connector_prefix}{YELLOW}#{num}{RESET} {title}")


def print_subtree_cli(branch, prefix, is_last, show_pr, visited=None):
    if visited is None:
        visited = set()
    if branch in visited:
        return
    visited.add(branch)

    connector    = "└── " if is_last else "├── "
    child_prefix = (prefix + "    ") if is_last else (prefix + "│   ")

    if show_pr:
        pr_info = get_pr_info(branch)
        print_node_lines(pr_info, prefix + connector, child_prefix, show_pr)
        print(f"{child_prefix}  {branch}")
    else:
        print(f"{prefix}{connector}{branch}")

    children = get_children(branch)
    for i, child in enumerate(children):
        print_subtree_cli(child, child_prefix, i == len(children) - 1, show_pr, visited)


def output_cli(chain, target_branch, show_pr):
    root = chain[0]
    print(f"{BOLD}{root}{RESET}")

    prefix = ""
    for b in chain[1:]:
        is_target = (b == target_branch)
        label = f"{BOLD}{CYAN}{b}{RESET}" if is_target else b
        next_prefix = prefix + "    "

        if show_pr:
            print_node_lines(get_pr_info(b), prefix + "└── ", next_prefix, show_pr)
            print(f"{next_prefix}  {label}")
        else:
            print(f"{prefix}└── {label}")
        prefix = next_prefix

        if is_target:
            children = get_children(target_branch)
            for ci, child in enumerate(children):
                print_subtree_cli(child, prefix, ci == len(children) - 1, show_pr)


# ===== HTML出力 =====

