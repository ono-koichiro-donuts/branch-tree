def output_html(chain, target_branch, show_pr):
    visited = set()

    def make_node_card(branch, is_root=False, is_target=False):
        """issue/PR/branchを含む .node カードHTMLを返す。"""
        b_url = branch_url(branch)
        node_cls = "leaf" + (" root" if is_root else "") + (" target" if is_target else "")
        link_cls = "branch-link" + (" root" if is_root else "") + (" target" if is_target else "")

        issue_lines = ""
        pr_line = ""
        if not is_root and show_pr:
            pr = get_pr_info(branch)
            if pr:
                issues = get_linked_issues(pr["number"])
                for issue in issues:
                    issue_lines += (
                        f'<span class="node-issue">'
                        f'<a class="issue" href="{esc(issue["url"])}" target="_blank">#{issue["number"]}</a>'
                        f' <a class="text-link" href="{esc(issue["url"])}" target="_blank">{esc(issue["title"])}</a>'
                        f'</span>'
                    )
                pr_line = (
                    f'<span class="node-pr">'
                    f'<a class="pr" href="{esc(pr["url"])}" target="_blank">#{pr["number"]}</a>'
                    f' <a class="text-link" href="{esc(pr["url"])}" target="_blank">{esc(pr["title"])}</a>'
                    f'</span>'
                )
            else:
                pr_line = '<span class="node-pr"><span class="no-pr">(no PR)</span></span>'

        branch_line = (
            f'<span class="node-branch">'
            f'<a class="{link_cls}" href="{esc(b_url)}" target="_blank">{esc(branch)}</a>'
            f'</span>'
        )
        return f'<div class="{node_cls}">{issue_lines}{pr_line}{branch_line}</div>'

    def subtree_trunk(branches):
        """branchesを <div class="trunk"> > node-row* に変換して返す。"""
        rows = []
        for b in branches:
            if b in visited:
                continue
            visited.add(b)
            card = make_node_card(b)
            children = get_children(b)
            child_trunk = subtree_trunk([c for c in children if c not in visited])
            rows.append(
                f'<div class="node-row">'
                f'<div class="branch"></div>'
                f'<div class="node-content">{card}{child_trunk}</div>'
                f'</div>'
            )
        if not rows:
            return ""
        return '<div class="trunk">' + "".join(rows) + "</div>"

    def chain_trunk(chain_remaining):
        """chain_remaining の各ノードを単一子の trunk として入れ子に変換して返す。"""
        if not chain_remaining:
            return ""
        b = chain_remaining[0]
        is_target = (b == target_branch)
        card = make_node_card(b, is_target=is_target)

        if is_target:
            children = get_children(target_branch)
            child_trunk = subtree_trunk([c for c in children if c not in visited])
        else:
            child_trunk = chain_trunk(chain_remaining[1:])

        return (
            '<div class="trunk">'
            '<div class="node-row">'
            '<div class="branch"></div>'
            f'<div class="node-content">{card}{child_trunk}</div>'
            '</div>'
            '</div>'
        )

    root = chain[0]
    visited.add(root)
    root_card = make_node_card(root, is_root=True)
    tree_html = root_card + chain_trunk(chain[1:])
    return HTML_TEMPLATE.format(target=esc(target_branch), tree_html=tree_html)


# ===== メイン =====

def main():
    parser = argparse.ArgumentParser(
        prog="branch-tree",
        description="ブランチの親子関係をツリー表示します"
    )
    parser.add_argument("branch", nargs="?", default=None, help="対象ブランチ（省略時はカレント）")
    parser.add_argument("--pr",    action="store_true", help="PR情報を表示")
    parser.add_argument("--html",  action="store_true", help="HTML形式で出力")
    parser.add_argument("--open",  action="store_true", help="HTMLを生成してブラウザで開く（--htmlを兼ねる）")
    parser.add_argument("--root",  default=None, help="ルートブランチを指定（.branch-treeに保存）")
    args = parser.parse_args()

    # ルートブランチの決定: --root > .branch-tree > デフォルト(develop)
    global ROOT_BRANCH
    if args.root:
        ROOT_BRANCH = args.root
        save_root_branch(args.root)
    else:
        saved = load_root_branch()
        if saved:
            ROOT_BRANCH = saved

    branch = args.branch
    if not branch:
        branch = run(["git", "branch", "--show-current"])
        if not branch:
            print("Error: カレントブランチを取得できません", file=sys.stderr)
            sys.exit(1)

    print("ブランチツリーを取得中...", file=sys.stderr)

    ancestors = collect_ancestors(branch)
    chain = ancestors if ancestors and ancestors[-1] == branch else ancestors + [branch]

    print(file=sys.stderr)

    if args.open or args.html:
        html = output_html(chain, branch, show_pr=True)
        if args.open:
            safe_name = re.sub(r'[^\w\-.]', '_', branch)
            path = f"/tmp/branch-tree-{safe_name}.html"
            with open(path, "w") as f:
                f.write(html)
            print(f"Opening {path} ...", file=sys.stderr)
            subprocess.run(["open", path])
        else:
            print(html)
    else:
        output_cli(chain, branch, show_pr=args.pr)


if __name__ == "__main__":
    main()
